[
  {
    "description": "anyOf",
    "schema": {
      "anyOf": [
        { "type": "integer" },
        { "minimum": 2 }
      ]
    },
    "tests": [
      { "description": "first anyOf valid", "data": 1, "valid": true },
      { "description": "second anyOf valid", "data": 2.5, "valid": true },
      { "description": "both anyOf valid", "data": 3, "valid": true },
      { "description": "neither anyOf valid", "data": 1.5, "valid": false }
    ]
  },
  {
    "description": "anyOf with base schema",
    "schema": {
      "type": "string",
      "anyOf": [
        { "maxLength": 2 },
        { "minLength": 4 }
      ]
    },
    "tests": [
      { "description": "short string is valid", "data": "hi", "valid": true },
      { "description": "long string is valid", "data": "hello", "valid": true },
      { "description": "medium string is invalid", "data": "abc", "valid": false },
      { "description": "wrong type is invalid", "data": 12, "valid": false }
    ]
  },
  {
    "description": "anyOf with multiple types",
    "schema": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" }
      ]
    },
    "tests": [
      { "description": "string is valid", "data": "hello", "valid": true },
      { "description": "number is valid", "data": 42, "valid": true },
      { "description": "boolean is valid", "data": true, "valid": true },
      { "description": "null is invalid", "data": null, "valid": false },
      { "description": "object is invalid", "data": {}, "valid": false }
    ]
  }
]
