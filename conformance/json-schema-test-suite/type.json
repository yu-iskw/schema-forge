[
  {
    "description": "type: string",
    "schema": { "type": "string" },
    "tests": [
      { "description": "string is valid", "data": "foo", "valid": true },
      { "description": "integer is invalid", "data": 1, "valid": false },
      { "description": "float is invalid", "data": 1.1, "valid": false },
      { "description": "object is invalid", "data": {}, "valid": false },
      { "description": "array is invalid", "data": [], "valid": false },
      {
        "description": "boolean true is invalid",
        "data": true,
        "valid": false
      },
      { "description": "null is invalid", "data": null, "valid": false }
    ]
  },
  {
    "description": "type: integer",
    "schema": { "type": "integer" },
    "tests": [
      { "description": "integer is valid", "data": 1, "valid": true },
      {
        "description": "float without fraction is valid",
        "data": 1.0,
        "valid": true
      },
      {
        "description": "float with fraction is invalid",
        "data": 1.5,
        "valid": false
      },
      { "description": "string is invalid", "data": "1", "valid": false },
      { "description": "null is invalid", "data": null, "valid": false }
    ]
  },
  {
    "description": "type: number",
    "schema": { "type": "number" },
    "tests": [
      { "description": "integer is valid", "data": 1, "valid": true },
      { "description": "float is valid", "data": 1.5, "valid": true },
      { "description": "string is invalid", "data": "1.1", "valid": false },
      { "description": "boolean is invalid", "data": true, "valid": false }
    ]
  },
  {
    "description": "type: object",
    "schema": { "type": "object" },
    "tests": [
      { "description": "object is valid", "data": {}, "valid": true },
      {
        "description": "non-empty object is valid",
        "data": { "a": 1 },
        "valid": true
      },
      { "description": "array is invalid", "data": [], "valid": false },
      { "description": "string is invalid", "data": "string", "valid": false }
    ]
  },
  {
    "description": "type: array",
    "schema": { "type": "array" },
    "tests": [
      { "description": "array is valid", "data": [], "valid": true },
      {
        "description": "non-empty array is valid",
        "data": [1, 2, 3],
        "valid": true
      },
      { "description": "object is invalid", "data": {}, "valid": false },
      { "description": "string is invalid", "data": "string", "valid": false }
    ]
  },
  {
    "description": "type: boolean",
    "schema": { "type": "boolean" },
    "tests": [
      { "description": "true is valid", "data": true, "valid": true },
      { "description": "false is valid", "data": false, "valid": true },
      { "description": "integer zero is invalid", "data": 0, "valid": false },
      { "description": "string is invalid", "data": "true", "valid": false }
    ]
  },
  {
    "description": "type: null",
    "schema": { "type": "null" },
    "tests": [
      { "description": "null is valid", "data": null, "valid": true },
      { "description": "zero is invalid", "data": 0, "valid": false },
      { "description": "false is invalid", "data": false, "valid": false },
      { "description": "empty string is invalid", "data": "", "valid": false }
    ]
  },
  {
    "description": "type: union (string or number)",
    "schema": { "type": ["string", "number"] },
    "tests": [
      { "description": "string is valid", "data": "foo", "valid": true },
      { "description": "number is valid", "data": 3.14, "valid": true },
      { "description": "null is invalid", "data": null, "valid": false },
      { "description": "object is invalid", "data": {}, "valid": false }
    ]
  }
]
